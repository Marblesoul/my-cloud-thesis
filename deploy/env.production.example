DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com,www.example.com,203.0.113.10
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
DJANGO_LOG_LEVEL=INFO

# Enable these after HTTPS is issued and nginx sends X-Forwarded-Proto.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_USE_X_FORWARDED_PROTO=True

DATABASE_URL=postgres://my_cloud:replace-db-password@127.0.0.1:5432/my_cloud
DJANGO_STATIC_ROOT=/var/www/my-cloud/backend/staticfiles
STORAGE_ROOT=/var/www/my-cloud/storage
INITIAL_ADMIN_PASSWORD=replace-admin-password
